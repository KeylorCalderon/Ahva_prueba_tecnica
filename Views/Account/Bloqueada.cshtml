@{
    ViewData["Title"] = "Cuenta Bloqueada";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow p-4 text-center border-danger" style="width: 100%; max-width: 450px;">
        <div class="mb-3">
            <i class="text-danger" style="font-size: 3rem;">&#128274;</i>
        </div>
        <h4 class="text-danger">Cuenta bloqueada temporalmente</h4>
        <p class="mt-3">
            Has excedido el máximo número de intentos fallidos.
            Tu cuenta se ha bloqueado por 15 minutos.
        </p>
        <a asp-action="Login" class="btn btn-outline-secondary mt-2">Volver al inicio de sesión</a>
    </div>
</div>